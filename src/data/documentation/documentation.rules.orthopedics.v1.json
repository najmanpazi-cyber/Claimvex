{
  "rules": [
    {
      "rule_id": "R-3.5.1",
      "description": "Missing laterality for unilateral orthopedic procedure",
      "action": "block",
      "severity": "Critical",
      "domain": "DOC_SUFFICIENCY",
      "laterality_modifiers": ["LT", "RT", "50"],
      "em_code_ranges": [
        { "start": "99202", "end": "99215" },
        { "start": "99221", "end": "99236" },
        { "start": "99281", "end": "99285" },
        { "start": "99241", "end": "99255" }
      ],
      "missing_info_keys": ["laterality"],
      "prompt_template": "Specify laterality: left, right, or bilateral",
      "policy_anchor": "CMS-1500 guidelines, CPT laterality modifier requirements"
    },
    {
      "rule_id": "R-3.5.2",
      "description": "ICD-10 laterality contradicts CPT laterality context",
      "action": "block",
      "severity": "Critical",
      "domain": "DOC_SUFFICIENCY",
      "missing_info_keys": [],
      "prompt_template": "ICD-10 {icd_code} indicates {icd_laterality} but procedure laterality is {cpt_laterality} — verify correct diagnosis code",
      "policy_anchor": "ICD-10-CM Official Guidelines, Section I.A.1 — laterality consistency"
    },
    {
      "rule_id": "R-3.5.3",
      "description": "Fracture care missing approach/technique",
      "action": "warn",
      "severity": "Medium",
      "domain": "DOC_SUFFICIENCY",
      "missing_info_keys": ["approach"],
      "prompt_template": "Specify fracture treatment approach: closed, closed with manipulation, open, or percutaneous",
      "policy_anchor": "CPT fracture care coding guidelines — approach determines code selection"
    },
    {
      "rule_id": "R-3.5.4",
      "description": "Outpatient rule-out/probable/suspected diagnosis",
      "action": "block",
      "severity": "High",
      "domain": "DOC_SUFFICIENCY",
      "outpatient_settings": ["office", "outpatient", "ASC"],
      "missing_info_keys": ["confirmed_diagnosis"],
      "prompt_template": "Outpatient setting requires confirmed diagnosis — replace rule-out language with confirmed condition or presenting symptom code",
      "policy_anchor": "ICD-10-CM Official Guidelines, Section IV — outpatient coding guidelines"
    },
    {
      "rule_id": "R-3.5.5",
      "description": "Missing anatomic specificity",
      "action": "warn",
      "severity": "Medium",
      "domain": "DOC_SUFFICIENCY",
      "missing_info_keys": ["anatomic_site"],
      "prompt_template": "Specify anatomic site with sufficient detail for code selection",
      "policy_anchor": "CPT coding guidelines — anatomic specificity requirements"
    }
  ],
